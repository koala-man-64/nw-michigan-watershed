{
  "info": {
    "name": "NW Michigan Watershed Coalition — Azure Functions API",
    "_postman_id": "f0a6b2d2-9e1a-44b3-8b3a-6d7c2a9b0b11",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Requests for `api/function_app.py` routes.\n\n- Local: set `baseUrl` to `localBaseUrl` (default)\n- Dev/Prod: set `baseUrl` to `devBaseUrl` / `prodBaseUrl` using Azure Static Web Apps hostnames only\n- Direct `*.azurewebsites.net` Function App hosts are unsupported for non-local testing\n- `POST /api/chat-rudy` is internal-only and returns 404 unless `CHAT_ENABLED=1`\n\nRoutes:\n- `GET /api/health`\n- `GET /api/ready`\n- `POST /api/chat-rudy`\n- `GET|POST /api/read-csv`\n- `POST /api/log-event`"
  },
  "item": [
    {
      "name": "chat-rudy — authenticated internal-only (200/404/429/500; requires CHAT_ENABLED=1 + auth)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" },
          { "key": "x-ms-client-principal", "value": "{{swaClientPrincipalB64}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"{{chat_message}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/chat-rudy"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200/404/429/500', function () { pm.expect([200, 404, 429, 500]).to.include(pm.response.code); });",
              "pm.test('Content-Type is JSON', function () {",
              "  const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
              "  pm.expect(ct).to.include('application/json');",
              "});",
              "const body = pm.response.json();",
              "pm.test('Has success or error shape', function () {",
              "  pm.expect(body).to.satisfy(b => Object.prototype.hasOwnProperty.call(b, 'reply') || Object.prototype.hasOwnProperty.call(b, 'error'));",
              "});",
              "if (pm.response.code === 200) {",
              "  pm.test('ok=true', function () { pm.expect(body.ok).to.eql(true); });",
              "  pm.test('Echoes message', function () { pm.expect(body.message).to.eql(pm.collectionVariables.get('chat_message')); });",
              "  pm.test('Has reply', function () { pm.expect(body.reply || '').to.be.a('string').and.to.have.length.above(0); });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "chat-rudy — unauthenticated internal-only (401/404; requires CHAT_ENABLED=1 to exercise auth path)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"{{chat_message}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/chat-rudy"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401 or 404', function () { pm.expect([401, 404]).to.include(pm.response.code); });",
              "const body = pm.response.json();",
              "if (pm.response.code === 401) {",
              "  pm.test('Has auth error', function () { pm.expect(body.error).to.eql('Authentication required'); });",
              "} else {",
              "  pm.test('Has disabled error', function () { pm.expect(body).to.have.property('error'); });",
              "}"
            ]
          }
        }
      ]
    },
    {
