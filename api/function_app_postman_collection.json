    {
      "name": "read-csv — forbidden blob (403; no storage needed)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": "{{baseUrl}}/api/read-csv?blob={{read_csv_forbidden_blob}}&format=json"
