{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Python Functions",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 9091
      },
      "preLaunchTask": "func: host start"
    },
    {
      "name": "Launch Client in Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/client",
      "preLaunchTask": "npm: start (client)"
    }
  ],
  "compounds": [
    {
      "name": "Run Full Application",
      "configurations": [
        "Attach to Python Functions",
        "Launch Client in Chrome"
      ],
      "stopAll": true
    }
  ]
}
