{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Full Application in Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/client",
      "preLaunchTask": "prepare full application"
    },
    {
      "name": "Launch Client Only in Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/client",
      "preLaunchTask": "npm: start (client)"
    }
  ]
}
