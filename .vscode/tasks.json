{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: start (client)",
      "type": "process",
      "windows": {
        "command": "cmd.exe",
        "args": [
          "/d",
          "/c",
          "npm start"
        ]
      },
      "linux": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "osx": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting the development server.*",
          "endsPattern": ".*Compiled successfully.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      }
    },
    {
      "type": "process",
      "label": "func: host start",
      "windows": {
        "command": "cmd.exe",
        "args": [
          "/d",
          "/c",
          "call start-local.cmd"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          ". ${config:azureFunctions.pythonVenv}/bin/activate && func host start --port 9091 --verbose"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          ". ${config:azureFunctions.pythonVenv}/bin/activate && func host start --port 9091 --verbose"
        ]
      },
      "problemMatcher": "$func-python-watch",
      "isBackground": true,
      "dependsOn": "pip install (functions)",
      "options": {
        "cwd": "${workspaceFolder}/api"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      }
    },
    {
      "label": "pip install (functions)",
      "type": "process",
      "osx": {
        "command": "${workspaceFolder}/api/.venv/bin/python",
        "args": [
          "-m",
          "pip",
          "install",
          "-r",
          "requirements.txt"
        ]
      },
      "windows": {
        "command": "cmd.exe",
        "args": [
          "/d",
          "/c",
          "call install-local-deps.cmd"
        ]
      },
      "linux": {
        "command": "${workspaceFolder}/api/.venv/bin/python",
        "args": [
          "-m",
          "pip",
          "install",
          "-r",
          "requirements.txt"
        ]
      },
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}/api"
      }
    },
    {
      "label": "start full application",
      "dependsOn": [
        "func: host start",
        "npm: start (client)"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
