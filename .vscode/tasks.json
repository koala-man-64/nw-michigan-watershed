{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: start (client)",
      "type": "process",
      "windows": {
        "command": "cmd.exe",
        "args": [
          "/d",
          "/c",
          "npm start"
        ]
      },
      "linux": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "osx": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting the development server.*",
          "endsPattern": ".*Compiled successfully.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      }
    },
    {
      "label": "npm: start (api)",
      "type": "process",
      "windows": {
        "command": "cmd.exe",
        "args": [
          "/d",
          "/c",
          "npm start"
        ]
      },
      "linux": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "osx": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*func start.*|.*Azure Functions Core Tools.*",
          "endsPattern": ".*Host lock lease acquired by instance ID.*|.*Functions:.*mapsToken.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/api"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      }
    },
    {
      "label": "start full application",
      "dependsOn": [
        "npm: start (api)",
        "npm: start (client)"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "export azure maps local settings (dev)",
      "type": "process",
      "windows": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\azuremaps\\Export-AzureMapsLocalSettings.ps1",
          "-Environment",
          "dev"
        ]
      },
      "linux": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-File",
          "${workspaceFolder}/scripts/azuremaps/Export-AzureMapsLocalSettings.ps1",
          "-Environment",
          "dev"
        ]
      },
      "osx": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-File",
          "${workspaceFolder}/scripts/azuremaps/Export-AzureMapsLocalSettings.ps1",
          "-Environment",
          "dev"
        ]
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      }
    },
    {
      "label": "prepare full application",
      "dependsOn": [
        "export azure maps local settings (dev)",
        "start full application"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
