{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: start (azurite)",
      "type": "process",
      "windows": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\local\\Ensure-Azurite.ps1"
        ]
      },
      "linux": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-File",
          "${workspaceFolder}/scripts/local/Ensure-Azurite.ps1"
        ]
      },
      "osx": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-File",
          "${workspaceFolder}/scripts/local/Ensure-Azurite.ps1"
        ]
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Ensuring Azurite.*|.*Starting Azurite with workspace.*|.*Azurite Blob service.*|.*Azurite Queue service.*|.*Azurite Table service.*|.*Azurite services already listening.*",
          "endsPattern": ".*Azurite Table service is successfully listening at.*10002.*|.*Azurite services already listening at.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "local-services"
      }
    },
    {
      "label": "npm: start (portal-web)",
      "type": "process",
      "windows": {
        "command": "cmd.exe",
        "args": [
          "/d",
          "/c",
          "npm start"
        ]
      },
      "linux": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "osx": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*|.*Local:.*",
          "endsPattern": ".*Local:.*3000.*|.*ready in.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/apps/portal-web"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      }
    },
    {
      "label": "npm: start (platform-api)",
      "type": "process",
      "windows": {
        "command": "cmd.exe",
        "args": [
          "/d",
          "/c",
          "npm start"
        ]
      },
      "linux": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "osx": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*func start.*|.*Azure Functions Core Tools.*",
          "endsPattern": ".*Host lock lease acquired by instance ID.*|.*Functions:.*mapsToken.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/apps/platform-api"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      },
      "dependsOn": [
        "npm: start (azurite)"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "npm: start (admin-web)",
      "type": "process",
      "windows": {
        "command": "cmd.exe",
        "args": [
          "/d",
          "/c",
          "npm run dev"
        ]
      },
      "linux": {
        "command": "npm",
        "args": [
          "run",
          "dev"
        ]
      },
      "osx": {
        "command": "npm",
        "args": [
          "run",
          "dev"
        ]
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*|.*Local:.*",
          "endsPattern": ".*Local:.*4173.*|.*ready in.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/apps/admin-web"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      }
    },
    {
      "label": "start portal application",
      "dependsOn": [
        "npm: start (platform-api)",
        "npm: start (portal-web)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "start admin application",
      "dependsOn": [
        "npm: start (platform-api)",
        "npm: start (admin-web)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "start full application",
      "dependsOn": [
        "npm: start (platform-api)",
        "npm: start (portal-web)",
        "npm: start (admin-web)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
