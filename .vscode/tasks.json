    {
      "label": "export azure maps local settings (prod)",
      "type": "process",
      "windows": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\azuremaps\\Export-AzureMapsLocalSettings.ps1",
          "-Environment",
          "prod"
        ]
      },
      "linux": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-File",
          "${workspaceFolder}/scripts/azuremaps/Export-AzureMapsLocalSettings.ps1",
          "-Environment",
          "prod"
        ]
      },
      "osx": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-File",
          "${workspaceFolder}/scripts/azuremaps/Export-AzureMapsLocalSettings.ps1",
          "-Environment",
          "prod"
        ]
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      }
    },
    {
      "label": "prepare portal application (dev)",
      "dependsOn": [
        "export azure maps local settings (dev)",
        "start portal application"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "prepare portal application (sbx)",
      "dependsOn": [
        "export azure maps local settings (sbx)",
        "start portal application"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "prepare admin application (dev)",
      "dependsOn": [
        "export azure maps local settings (dev)",
        "start admin application"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "prepare admin application (sbx)",
      "dependsOn": [
        "export azure maps local settings (sbx)",
        "start admin application"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "prepare portal application (prod)",
      "dependsOn": [
        "export azure maps local settings (prod)",
        "start portal application"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "prepare admin application (prod)",
      "dependsOn": [
        "export azure maps local settings (prod)",
        "start admin application"
      ],
      "dependsOrder": "sequence",
