{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: start (client)",
      "type": "process",
      "windows": {
        "command": "cmd.exe",
        "args": [
          "/d",
          "/c",
          "npm start"
        ]
      },
      "linux": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "osx": {
        "command": "npm",
        "args": [
          "start"
        ]
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting the development server.*",
          "endsPattern": ".*Compiled successfully.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "full-application"
      }
    },
    {
      "label": "start full application",
      "dependsOn": "npm: start (client)",
      "problemMatcher": []
    }
  ]
}
