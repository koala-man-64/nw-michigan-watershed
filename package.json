{
  "name": "nwmiws-platform",
  "private": true,
  "version": "2.0.0",
  "description": "Business-oriented platform workspace for the NW Michigan watershed applications",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
